# Server configuration
PORT=4000

# Database connection
DATABASE_URL=postgres://localhost/job_assistant

# Set to 'false' to run browser in headed mode (visible window)
HEADLESS=true

# JWT secret for signing auth tokens (use a long random string in production)
JWT_SECRET=change-me-to-a-long-random-string

# Azure Blob Storage connection string (from your Azure Storage account)
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net

# Azure Blob Storage container name (will be created if it doesn't exist)
AZURE_STORAGE_CONTAINER_NAME=uploads

# Optional: LLM API key for cover letter generation
# OPENAI_API_KEY=sk-...

# Optional: Redis for BullMQ job queue
# REDIS_URL=redis://localhost:6379

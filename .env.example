# Server configuration
PORT=4000
NODE_ENV=development

# Database connection
DATABASE_URL=postgresql://postgres:password@localhost:5432/job_buddy

# JWT configuration
JWT_SECRET=change-this-to-a-secure-random-string-in-production
JWT_EXPIRES_IN=7d

# Set to 'false' to run browser in headed mode (visible window)
HEADLESS=true

# Optional: LLM API key for cover letter generation
# OPENAI_API_KEY=sk-...
